<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Circular Image -->
    <style name="CircularImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Section Title -->
    <style name="SectionTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?android:textColorPrimary</item>
    </style>

    <!-- Subtitle -->
    <style name="SubtitleText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Price Text -->
    <style name="PriceText">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primaryRed</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Dimension constants -->
    <dimen name="card_margin">12dp</dimen>
    <dimen name="card_padding">16dp</dimen>
    <dimen name="page_padding">16dp</dimen>
    <dimen name="section_spacing">24dp</dimen>
    <dimen name="item_spacing">12dp</dimen>
</resources>
