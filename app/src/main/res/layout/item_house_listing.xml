<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    card:cardCornerRadius="18dp"
    card:cardElevation="3dp"
    card:cardBackgroundColor="?colorSurface"
    android:foreground="?selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Image Container with Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/imgHouse"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/house" />

            <!-- Bottom gradient for text over image -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_overlay" />

            <!-- Favorite Button -->
            <ImageView
                android:id="@+id/btnFavorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:padding="8dp"
                android:src="@drawable/ic_favorite_border"
                android:background="@drawable/rounded_chip_bg"
                android:contentDescription="Favorite" />

            <!-- Rating Badge -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_chip_bg"
                android:padding="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_star"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/textDark" />

            </LinearLayout>

            <!-- Price Badge -->
            <TextView
                android:id="@+id/tvPriceBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_chip_bg"
                android:padding="6dp"
                android:text="$120/night"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primaryRed" />

        </FrameLayout>

        <!-- Card Content -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Luxury Beach House"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="sans-serif-medium" />

            <!-- Location Row -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Malibu, California"
                    android:textSize="13sp"
                    android:textColor="?android:textColorSecondary" />

            </LinearLayout>

            <!-- Specs Row -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Guests -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_people"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvGuests"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 Guests"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                </LinearLayout>

                <!-- Bedrooms -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_bed"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvBedrooms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Beds"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                </LinearLayout>

                <!-- Bathrooms -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_bathtub"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvBathrooms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Baths"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
