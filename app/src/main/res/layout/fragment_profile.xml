<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_v5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.05" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_v95"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.95" />

                <FrameLayout
                    android:id="@+id/avatar_container"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:layout_constraintStart_toStartOf="@id/gl_v5"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:id="@+id/view_avatar_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_circle" />

                    <TextView
                        android:id="@+id/tv_avatar_initial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_header_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Full Name"
                    android:textColor="@color/colorTextDark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@id/gl_v95"
                    app:layout_constraintStart_toEndOf="@id/avatar_container"
                    app:layout_constraintTop_toTopOf="@id/avatar_container" />

                <TextView
                    android:id="@+id/tv_header_email"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textColor="@color/colorTextMedium"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@id/gl_v95"
                    app:layout_constraintStart_toStartOf="@id/tv_header_name"
                    app:layout_constraintTop_toBottomOf="@id/tv_header_name" />

                <TextView
                    android:id="@+id/tv_role_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="Guest"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@id/tv_header_name"
                    app:layout_constraintTop_toBottomOf="@id/tv_header_email" />

                <TextView
                    android:id="@+id/tv_member_since"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Member since 2024"
                    android:textColor="@color/colorTextLight"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@id/tv_header_name"
                    app:layout_constraintTop_toBottomOf="@id/tv_role_badge" />

                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/barrier_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="avatar_container,tv_member_since" />

                <LinearLayout
                    android:id="@+id/ll_stats_row"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="@id/gl_v95"
                    app:layout_constraintStart_toStartOf="@id/gl_v5"
                    app:layout_constraintTop_toBottomOf="@id/barrier_header">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stat_wishlists"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorTextDark"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wishlists"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/colorBorder" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stat_bookings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorTextDark"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bookings"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/colorBorder" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stat_searches"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorTextDark"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Searches"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- About Me Section -->
        <TextView
            android:id="@+id/tv_about_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/about_me"
            android:textColor="@color/colorTextDark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_header" />

        <EditText
            android:id="@+id/et_profile_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_white"
            android:hint="@string/full_name"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_about_label" />

        <EditText
            android:id="@+id/et_profile_bio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_white"
            android:gravity="top"
            android:hint="Tell us about yourself..."
            android:minLines="3"
            android:padding="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_profile_name" />

        <EditText
            android:id="@+id/et_profile_phone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_white"
            android:hint="Phone number"
            android:inputType="phone"
            android:padding="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_profile_bio" />

        <Button
            android:id="@+id/btn_save_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="24dp"
            android:text="@string/save_profile"
            android:textColor="@color/white"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_profile_phone" />

        <!-- Preferences Section -->
        <TextView
            android:id="@+id/tv_prefs_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/preferences"
            android:textColor="@color/colorTextDark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_save_profile" />

        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/flow_prefs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:constraint_referenced_ids="chip_dark_mode,chip_email_notif,chip_push_alerts,chip_price_alerts,chip_new_listings,chip_weekly_digest"
            app:flow_horizontalGap="8dp"
            app:flow_verticalGap="8dp"
            app:flow_wrapMode="chain"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_prefs_label" />

        <CheckBox android:id="@+id/chip_dark_mode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dark Mode" android:button="@null" android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:textColor="@color/colorPrimary" />
        <CheckBox android:id="@+id/chip_email_notif" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Notifications" android:button="@null" android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:textColor="@color/colorPrimary" />
        <CheckBox android:id="@+id/chip_push_alerts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Push Alerts" android:button="@null" android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:textColor="@color/colorPrimary" />
        <CheckBox android:id="@+id/chip_price_alerts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Price Alerts" android:button="@null" android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:textColor="@color/colorPrimary" />
        <CheckBox android:id="@+id/chip_new_listings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Listings" android:button="@null" android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:textColor="@color/colorPrimary" />
        <CheckBox android:id="@+id/chip_weekly_digest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly Digest" android:button="@null" android:background="@drawable/bg_chip_unselected" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:textColor="@color/colorPrimary" />

        <!-- Recent Searches Section -->
        <TextView
            android:id="@+id/tv_recent_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/recent_searches"
            android:textColor="@color/colorTextDark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flow_prefs" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent_searches"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_recent_label" />

        <!-- Danger Zone -->
        <Button
            android:id="@+id/btn_logout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/logout"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/rv_recent_searches" />

        <Button
            android:id="@+id/btn_delete_account"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="@string/delete_account"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/btn_logout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>