<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card="http://schemas.android.com/apk/res-auto"
    card:cardCornerRadius="16dp"
    card:cardElevation="4dp"
    card:cardBackgroundColor="?colorSurface"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title row with remove button -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_favorite"
                card:tint="@color/primaryRed"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvFavTitle"
                android:text="Listing Title"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />

            <ImageButton
                android:id="@+id/btnRemoveFav"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@string/remove_from_favorites"
                card:tint="?android:textColorSecondary" />

        </LinearLayout>

        <!-- Price badge -->
        <TextView
            android:id="@+id/tvFavPrice"
            android:text="$120/night"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primaryRed"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Amenities -->
        <TextView
            android:id="@+id/tvFavAmenities"
            android:text="Free WiFi, Pool, Kitchen"
            android:textSize="13sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lightDivider"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp" />

        <!-- Personal note and Edit button -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            
            <TextView
                android:id="@+id/tvFavNote"
                android:text="📝 No personal note"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="?android:textColorSecondary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
                
            <TextView
                android:id="@+id/btnEditNote"
                android:text="Edit Note"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primaryRed"
                android:padding="8dp"
                android:background="?selectableItemBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
